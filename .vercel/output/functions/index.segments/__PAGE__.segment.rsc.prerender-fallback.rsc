s":["detectors","detectivity","sensor","noise","qe","responsivity","nep"],"priority":50},{"title":"Detector Responsivity","href":"/detectors/responsivity","description":"Interactive detector responsivity calculator from quantum efficiency and wavelength, with wavelength sweeps and presets.","kind":"page","category":"detectors","tags":["detectors","responsivity","sensor","noise","qe","nep","detectivity"],"priority":50},{"title":"Diamond Optics","href":"/materials/diamond-optics","description":"Diamond — the ultimate optical material. Bandgap: 5.47 eV. n ≈ 2.42.","kind":"page","category":"materials","tags":["materials","diamond-optics","sellmeier","dispersion","glass","index","material properties"],"priority":50},{"title":"Dichroic Beam Splitter","href":"/thin-film/dichroic","description":"Dichroic beam splitter at oblique incidence. Shows s- and p-polarisation splitting characteristic of dichroic filters used at 45°. Effective optical thickness shifts with cos(θ).","kind":"page","category":"thin-film","tags":["thin-film","dichroic","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Dichroic Polarizer","href":"/polarization/dichroic-polarizer","description":"Model absorption-based dichroic polarizers using complex refractive indices. One polarization state is strongly absorbed while the other transmits.","kind":"page","category":"polarization","tags":["polarization","dichroic-polarizer","stokes","jones","mueller","waveplate","polarizer"],"priority":50},{"title":"Dielectric High Reflector","href":"/thin-film/dielectric-high-reflector","description":"Quarter-wave dielectric stack HR mirror — stopband width, peak reflectance, and dispersion.","kind":"page","category":"thin-film","tags":["thin-film","dielectric-high-reflector","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Dielectric Stack Theory","href":"/thin-film/dielectric-stack","description":"Quarter-wave dielectric stack reflectance. Alternating high/low index layers create high-reflectance mirrors — the basis of dielectric mirrors and VCSELs.","kind":"page","category":"thin-film","tags":["thin-film","dielectric-stack","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Difference Frequency Generation","href":"/spectroscopy/difference-frequency-gen","description":"Generate tunable mid-IR via DFG: ω_idler = ω_pump − ω_signal. Essential for IR spectroscopy sources.","kind":"page","category":"spectroscopy","tags":["spectroscopy","difference-frequency-gen","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Difference Frequency Generation (DFG)","href":"/wave-optics/difference-frequency","description":"Downconversion via χ⁽²⁾: ωp − ωs → ωi for mid-IR generation.","kind":"page","category":"wave-optics","tags":["wave-optics","difference-frequency","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Diffraction Integral Calculator","href":"/wave-optics/diffraction-integral","description":"Fresnel/Kirchhoff diffraction patterns.","kind":"page","category":"wave-optics","tags":["wave-optics","diffraction-integral","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Diffuse Reflection Hazard","href":"/laser-safety/diffuse-reflection","description":"Evaluate hazard from Lambertian (diffuse) reflections off matte surfaces. Uses extended-source MPE.","kind":"page","category":"laser-safety","tags":["laser-safety","diffuse-reflection","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Digital Holography","href":"/imaging/digital-holography","description":"Hologram recording, numerical reconstruction, resolution limits, and sampling criteria.","kind":"page","category":"imaging","tags":["imaging","digital-holography","resolution","na","microscopy","airy","mtf","psf"],"priority":50},{"title":"Diode Laser Resonator","href":"/wave-optics/diode-laser-resonator","description":"Open Diode Laser Resonator.","kind":"page","category":"wave-optics","tags":["wave-optics","diode-laser-resonator","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Diode Laser Safety Calculator","href":"/laser-safety/diode-laser-safety","description":"Calculate MPE, NOHD, and OD requirements for diode laser bars/stacks with asymmetric divergence.","kind":"page","category":"laser-safety","tags":["laser-safety","diode-laser-safety","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Dispersion Compensation","href":"/fiber-optics/dispersion-comp","description":"Calculates chromatic dispersion limits and DCF (dispersion-compensating fiber) requirements. Total dispersion: Dtotal = D · L. Pulse broadening: Δτ = Dtotal · Δλ. NRZ bit-rate limit: B ≤ 1/(4Δτ). DCF length: LDCF = D·L / |DDCF|.","kind":"page","category":"fiber-optics","tags":["fiber-optics","dispersion-comp","fiber","mfd","na","dispersion","splice","coupling"],"priority":50},{"title":"Dispersion Compensation","href":"/fiber-optics/dispersion-compensation","description":"GVD and TOD compensation analysis for fiber optic links.","kind":"page","category":"fiber-optics","tags":["fiber-optics","dispersion-compensation","fiber","mfd","na","dispersion","splice","coupling"],"priority":50},{"title":"Dispersion Map Calculator","href":"/fiber-optics/dispersion-map","description":"Design a dispersion map for a fiber link using SMF and DCF segments.","kind":"page","category":"fiber-optics","tags":["fiber-optics","dispersion-map","fiber","mfd","na","dispersion","splice","coupling"],"priority":50},{"title":"Dispersion Shifted","href":"/fiber-optics/dispersion-shifted","description":"Open Dispersion Shifted.","kind":"page","category":"fiber-optics","tags":["fiber-optics","dispersion-shifted","fiber","mfd","na","dispersion","splice","coupling"],"priority":50},{"title":"Dispersive Element Design","href":"/spectroscopy/dispersive-element","description":"Diffraction grating parameters: grating equation, angular/linear dispersion, blaze profile.","kind":"page","category":"spectroscopy","tags":["spectroscopy","dispersive-element","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Diversity Reception","href":"/free-space-comms/diversity-reception","description":"Open Diversity Reception.","kind":"page","category":"free-space-comms","tags":["free-space-comms","diversity-reception","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Doppler Broadening Calculator","href":"/spectroscopy/doppler-broadening","description":"Calculate Doppler (thermal) line broadening FWHM from gas temperature and atomic/molecular mass.","kind":"page","category":"spectroscopy","tags":["spectroscopy","doppler-broadening","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Double Refraction (Birefringence)","href":"/polarization/double-refraction","description":"Calculate ordinary and extraordinary ray paths, walk-off angle, lateral separation, and retardation in uniaxial crystals.","kind":"page","category":"polarization","tags":["polarization","double-refraction","stokes","jones","mueller","waveplate","polarizer"],"priority":50},{"title":"Dual-Band AR Coating","href":"/thin-film/dual-band-ar","description":"Three-layer anti-reflection coating optimized for two distinct wavelength bands.","kind":"page","category":"thin-film","tags":["thin-film","dual-band-ar","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Dual-Comb Spectroscopy","href":"/wave-optics/dual-comb-spectroscopy","description":"High-resolution spectroscopy using two frequency combs with slightly different repetition rates.","kind":"page","category":"wave-optics","tags":["wave-optics","dual-comb-spectroscopy","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Dual-Comb Spectroscopy Calculator","href":"/spectroscopy/dual-comb-spectroscopy","description":"Model dual-comb spectroscopy parameters: resolution, bandwidth, update rate, and multi-heterodyne RF spectrum.","kind":"page","category":"spectroscopy","tags":["spectroscopy","dual-comb-spectroscopy","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Dye Laser Resonator","href":"/wave-optics/dye-laser-resonator","description":"Open Dye Laser Resonator.","kind":"page","category":"wave-optics","tags":["wave-optics","dye-laser-resonator","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Dynamic Range Calculator","href":"/imaging/dynamic-range","description":"Imaging system dynamic range, noise floor, and ADC-limited performance analysis.","kind":"page","category":"imaging","tags":["imaging","dynamic-range","resolution","na","microscopy","airy","mtf","psf"],"priority":50},{"title":"Edge Filter Design","href":"/thin-film/edge-filter","description":"{type === &quot;long&quot; ? &quot;Long-pass&quot; : &quot;Short-pass&quot;} edge filter — quarter-wave stack transition region and cut-on/cut-off wavelength.","kind":"page","category":"thin-film","tags":["thin-film","edge-filter","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Electro-Optic Coefficients","href":"/materials/electro-optic","description":"Pockels effect materials for modulators, Q-switches, and phase shifters","kind":"page","category":"materials","tags":["materials","electro-optic","sellmeier","dispersion","glass","index","material properties"],"priority":50},{"title":"Electron Spectroscopy (XPS/UPS)","href":"/spectroscopy/electron-spectroscopy","description":"Photoelectron spectroscopy for surface composition, chemical state, and electronic structure.","kind":"page","category":"spectroscopy","tags":["spectroscopy","electron-spectroscopy","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Ellipsometry","href":"/polarization/ellipsometry","description":"Calculate Ψ, Δ from Fresnel equations; model thin film interference in ellipsometry.","kind":"page","category":"polarization","tags":["polarization","ellipsometry","stokes","jones","mueller","waveplate","polarizer"],"priority":50},{"title":"Ellipsometry Measurement","href":"/thin-film/ellipsometry-measurement","description":"Analyze ellipsometry data (Ψ, Δ) to extract pseudo-dielectric function, refractive index, and approximate film thickness.","kind":"page","category":"thin-film","tags":["thin-film","ellipsometry-measurement","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"EMCCD Gain Calculator","href":"/detectors/em-gain","description":"EM gain — noise analysis, optimal gain, and SNR comparison.","kind":"page","category":"detectors","tags":["detectors","em-gain","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"EMCCD Gain Calculator","href":"/detectors/emccd-gain","description":"EM gain stages, excess noise (F=√2), and SNR advantage over conventional CCD.","kind":"page","category":"detectors","tags":["detectors","emccd-gain","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"EMCCD vs sCMOS","href":"/detectors/electron-multiplying","description":"Compare electron-multiplying CCD with sCMOS for low-light imaging.","kind":"page","category":"detectors","tags":["detectors","electron-multiplying","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"Emission Spectra Fitting","href":"/spectroscopy/emission-spectra","description":"Model photoluminescence emission with asymmetric Gaussian line shapes.","kind":"page","category":"spectroscopy","tags":["spectroscopy","emission-spectra","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Emissivity Control","href":"/thin-film/emissivity-control","description":"Low-emissivity (Low-E) coating for thermal insulation — Kirchhoff's law: ε = 1 - R.","kind":"page","category":"thin-film","tags":["thin-film","emissivity-control","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Enclosure Classification","href":"/laser-safety/enclosure-class","description":"Determines laser enclosure safety class based on emission through apertures, per IEC 60825-1 and ANSI Z136.1. Evaluates whether the enclosure provides Class 1 protection.","kind":"page","category":"laser-safety","tags":["laser-safety","enclosure-class","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Enhanced Aluminum Mirror","href":"/thin-film/enhanced-aluminum","description":"Aluminum mirror with dielectric overcoat to boost reflectance in the visible.","kind":"page","category":"thin-film","tags":["thin-film","enhanced-aluminum","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Environmental Stability","href":"/thin-film/environmental-stability","description":"Environmental factors shift thin film spectral performance. Temperature changes refractive index (thermo-optic effect, dn/dT) and layer thickness (thermal expansion, CTE). Humidity causes water absorption in porous layers (especially SiO₂), changing both n and d. Dense films (TiO₂, Ta₂O₅) are more environmentally stable. Understanding these shifts is critical for field deployment.","kind":"page","category":"thin-film","tags":["thin-film","environmental-stability","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Etalon / Fabry-Pérot Analysis","href":"/wave-optics/etalon-finesse","description":"Detailed etalon transmission, finesse, and spectral properties.","kind":"page","category":"wave-optics","tags":["wave-optics","etalon-finesse","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Etalon Free Spectral Range","href":"/spectroscopy/etalon-fsr","description":"Fabry-Pérot etalon: FSR = λ²/(2nd cos θ). Transmission follows the Airy function.","kind":"page","category":"spectroscopy","tags":["spectroscopy","etalon-fsr","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Excess Noise Factor","href":"/detectors/excess-noise","description":"APD excess noise vs gain — McIntyre model for different semiconductor materials.","kind":"page","category":"detectors","tags":["detectors","excess-noise","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"Expansion Microscopy Calculator","href":"/imaging/expansion-microscopy","description":"ExM effective resolution, probe size reduction, and expansion trade-offs.","kind":"page","category":"imaging","tags":["imaging","expansion-microscopy","resolution","na","microscopy","airy","mtf","psf"],"priority":50},{"title":"Extended Source Correction (C₆)","href":"/laser-safety/extended-source","description":"C₆ angular subtense correction factor for extended source laser hazard evaluation per ANSI Z136.","kind":"page","category":"laser-safety","tags":["laser-safety","extended-source","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Extinction Coefficient","href":"/spectroscopy/extinction-coefficient","description":"Calculate molar and specific extinction coefficients from absorbance measurements. Beer-Lambert law: ε = A / (c·l).","kind":"page","category":"spectroscopy","tags":["spectroscopy","extinction-coefficient","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Extinction Ratio","href":"/polarization/extinction-ratio","description":"Calculate polarizer extinction ratio, transmission, and cascaded performance.","kind":"page","category":"polarization","tags":["polarization","extinction-ratio","stokes","jones","mueller","waveplate","polarizer"],"priority":50},{"title":"Eye Safety Fso","href":"/free-space-comms/eye-safety-fso","description":"Open Eye Safety Fso.","kind":"page","category":"free-space-comms","tags":["free-space-comms","eye-safety-fso","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Eye-Safe Wavelength Region","href":"/laser-safety/eye-safe-wavelength","description":"Identifies the eye-safe wavelength bands (1400–1500 nm, 1500–1800 nm) where corneal absorption protects the retina. Compare your laser&apos;s fluence against spectral MPE.","kind":"page","category":"laser-safety","tags":["laser-safety","eye-safe-wavelength","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Fabry-Pérot Filter","href":"/thin-film/fabry-perot-filter","description":"Fabry-Pérot etalon/filter transmission based on the Airy function. Explore how mirror reflectance and cavity spacing control spectral selectivity.","kind":"page","category":"thin-film","tags":["thin-film","fabry-perot-filter","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Fade Probability","href":"/free-space-comms/fade-probability","description":"Open Fade Probability.","kind":"page","category":"free-space-comms","tags":["free-space-comms","fade-probability","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"FCS Calculator","href":"/imaging/fcs","description":"Fluorescence Correlation Spectroscopy — diffusion time, concentration, and confocal volume.","kind":"page","category":"imaging","tags":["imaging","fcs","resolution","na","microscopy","airy","mtf","psf"],"priority":50},{"title":"Fiber Amplifier","href":"/fiber-optics/fiber-amplifier","description":"Open Fiber Amplifier.","kind":"page","category":"fiber-optics","tags":["fiber-optics","fiber-amplifier","fiber","mfd","na","dispersion","splice","coupling"],"priority":50},{"title":"Fiber Bandwidth Calculation","href":"/fiber-optics/fiber-bandwidth","description":"Calculate bandwidth limitations from chromatic dispersion, modal dispersion (MMF), and PMD for various fiber types and link configurations.","kind":"page","category":"fiber-optics","tags":["fiber-optics","fiber-bandwidth","fiber","mfd","na","dispersion","splice","coupling"],"priority":50},{"title