 font-medium text-white transition hover:border-white/20 hover:bg-white/[0.06]","children":"Browse all categories"}]]}],["$","$L3",null,{"items":[{"title":"Gaussian Beam Propagation","href":"/wave-optics/gaussian-beam","description":"Explore how wavelength and waist size shape Rayleigh range, divergence, and Gaussian beam envelope.","kind":"page","category":"wave-optics","tags":["wave-optics","gaussian-beam","gaussian beam","abcd","cavity","mode matching","diffraction","rayleigh range","beam waist","divergence"],"priority":100},{"title":"Fiber Coupling Efficiency","href":"/fiber-optics/coupling-efficiency","description":"Estimate Gaussian-to-fiber coupling loss from NA mismatch, lateral offset, and angular misalignment.","kind":"page","category":"fiber-optics","tags":["fiber-optics","coupling-efficiency","fiber","mfd","na","dispersion","splice","coupling","fiber coupling","alignment","insertion loss"],"priority":98},{"title":"Single Layer AR Coating","href":"/thin-film/single-ar","description":"Quarter-wave antireflection coating design with Snell's law and explicit s/p polarization handling at oblique incidence.","kind":"page","category":"thin-film","tags":["thin-film","single-ar","coating","ar","dielectric stack","bragg","reflectance","anti reflection","quarter wave","fresnel"],"priority":98},{"title":"Blackbody Radiation","href":"/spectroscopy/blackbody","description":"Planck's law spectral radiance, Wien displacement, and Stefan-Boltzmann total power.","kind":"page","category":"spectroscopy","tags":["spectroscopy","blackbody","beer lambert","ftir","raman","wavenumber","planck","wien","stefan boltzmann","thermal radiation"],"priority":96},{"title":"FTIR Resolution Calculator","href":"/spectroscopy/ftir-resolution","description":"FTIR spectral resolution from maximum OPD, apodization, and scan parameters.","kind":"page","category":"spectroscopy","tags":["spectroscopy","ftir-resolution","beer lambert","ftir","blackbody","raman","wavenumber","interferometer","opd","apodization","resolution"],"priority":96},{"title":"Airy Disk Size Calculator","href":"/imaging/airy-disk","description":"Calculate the Airy disk radius and Abbe diffraction limit from wavelength and numerical aperture.","kind":"page","category":"imaging","tags":["imaging","airy-disk","resolution","na","microscopy","airy","mtf","psf","diffraction limit","abbe","spot size"],"priority":94},{"title":"Lambert-Beer Law Calculator","href":"/spectroscopy/lambert-beer-law","description":"Beer-Lambert absorbance, optical density, and transmission with interactive parameter sweeps.","kind":"page","category":"spectroscopy","tags":["spectroscopy","lambert-beer-law","beer lambert","ftir","blackbody","raman","wavenumber","absorbance","optical density","transmission"],"priority":94},{"title":"S₁/Q","href":"/polarization/stokes","description":"Analyze polarization state from Stokes vector components with Poincaré-sphere visualization.","kind":"page","category":"polarization","tags":["polarization","stokes","jones","mueller","waveplate","polarizer","poincare sphere","polarization state","stokes vector"],"priority":94},{"title":"Sellmeier Equation","href":"/materials/sellmeier","description":"Calculate refractive index from Sellmeier coefficients across wavelength.","kind":"page","category":"materials","tags":["materials","sellmeier","dispersion","glass","index","material properties","dispersion formula","refractive index","glass catalog"],"priority":94},{"title":"Exposure time (s)","href":"/laser-safety/mpe","description":"Bounded CW point-source MPE pre-check for 400–1050 nm and 1 ms to 3×10^4 s using explicitly implemented ANSI-style table slices.","kind":"page","category":"laser-safety","tags":["laser-safety","mpe","laser safety","nohd","od","eyewear","hazard","maximum permissible exposure"],"priority":92},{"title":"Nominal Ocular Hazard Distance (NOHD)","href":"/laser-safety/nohd","description":"Bounded CW point-source NOHD pre-check derived from the same direct-beam ocular MPE branch as the MPE page.","kind":"page","category":"laser-safety","tags":["laser-safety","nohd","laser safety","mpe","od","eyewear","hazard","nominal ocular hazard distance"],"priority":90},{"title":"Optical Density (CW point-source pre-check)","href":"/laser-safety/optical-density","description":"Bounded CW point-source optical-density pre-check derived from the same MPE branch as the MPE page.","kind":"page","category":"laser-safety","tags":["laser-safety","optical-density","laser safety","mpe","nohd","od","eyewear","hazard","laser eyewear","od calculator"],"priority":88},{"title":"OD Requirements (manual validated-limit mode)","href":"/laser-safety/od-requirements","description":"Manual validated-limit optical-density math for laser safety workflows when the irradiance limit has already been obtained externally.","kind":"page","category":"laser-safety","tags":["laser-safety","od-requirements","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":86},{"title":"Safe Viewing Distance (CW point-source pre-check)","href":"/laser-safety/viewing-distance","description":"Bounded CW point-source direct-beam viewing-distance pre-check using the same assumptions as the MPE and NOHD pages.","kind":"page","category":"laser-safety","tags":["laser-safety","viewing-distance","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":84},{"title":"Fiber Optics Calculators","href":"/fiber-optics","description":"Fiber optics calculators for coupling, dispersion, bend loss, V-number, nonlinear thresholds, and guided-wave design.","kind":"category","category":"fiber-optics","tags":["fiber-optics","fiber","mfd","na","dispersion","splice","coupling"],"priority":60},{"title":"Imaging Calculators","href":"/imaging","description":"Optical imaging calculators for resolution, PSF, depth of field, microscopy, OCT, and wavefront-driven imaging analysis.","kind":"category","category":"imaging","tags":["imaging","resolution","na","microscopy","airy","mtf","psf"],"priority":60},{"title":"Optical Materials Calculators","href":"/materials","description":"Optical materials calculators for refractive index, Sellmeier fits, thermal properties, absorption, and nonlinear material behavior.","kind":"category","category":"materials","tags":["materials","sellmeier","dispersion","glass","index","material properties"],"priority":60},{"title":"Polarization Calculators","href":"/polarization","description":"Polarization calculators for Jones and Stokes analysis, retarders, birefringence, Mueller matrices, and waveplate design.","kind":"category","category":"polarization","tags":["polarization","stokes","jones","mueller","waveplate","polarizer"],"priority":60},{"title":"Spectroscopy Calculators","href":"/spectroscopy","description":"Spectroscopy calculators for FTIR, Raman, spectral resolution, calibration, line broadening, and signal analysis.","kind":"category","category":"spectroscopy","tags":["spectroscopy","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":60},{"title":"Thin Film Calculators","href":"/thin-film","description":"Thin-film optics calculators for AR coatings, dielectric stacks, dichroics, reflectors, interference filters, and deposition effects.","kind":"category","category":"thin-film","tags":["thin-film","coating","ar","dielectric stack","bragg","reflectance"],"priority":60},{"title":"Wave Optics Calculators","href":"/wave-optics","description":"Wave optics calculators for Gaussian beams, cavities, diffraction, interferometers, nonlinear propagation, and laser resonators.","kind":"category","category":"wave-optics","tags":["wave-optics","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":60},{"title":"Laser Safety Calculators","href":"/laser-safety","description":"Educational laser safety calculators with explicit trust boundaries. Separate bounded CW point-source pre-check tools from general educational references and quarantined standards-heavy topics.","kind":"category","category":"laser-safety","tags":["laser-safety","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":55},{"title":"1/f Flicker Noise","href":"/detectors/flicker-noise","description":"Flicker noise: S_v(f) = K_f · I^α / f. Noise spectral density falls as 1/f.","kind":"page","category":"detectors","tags":["detectors","flicker-noise","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"3D Reconstruction Methods","href":"/imaging/3d-reconstruction","description":"Compare 3D reconstruction approaches: resolution, sampling, voxel budgets, and method tradeoffs.","kind":"page","category":"imaging","tags":["imaging","3d-reconstruction","resolution","na","microscopy","airy","mtf","psf"],"priority":50},{"title":"Abbe Number (Vd)","href":"/materials/abbe-number","description":"Calculate Abbe number from Sellmeier coefficients. Vd = (nD - 1)/(nF - nC).","kind":"page","category":"materials","tags":["materials","abbe-number","sellmeier","dispersion","glass","index","material properties"],"priority":50},{"title":"ABCD Matrix Calculator","href":"/wave-optics/abcd-matrix","description":"Build an optical system from sequential elements and compute the ray transfer matrix.","kind":"page","category":"wave-optics","tags":["wave-optics","abcd-matrix","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Absorption Coefficient","href":"/materials/absorption","description":"Wavelength-dependent absorption coefficient α(λ) and transmission through material thickness.","kind":"page","category":"materials","tags":["materials","absorption","sellmeier","dispersion","glass","index","material properties"],"priority":50},{"title":"Absorption Cross-Section Calculator","href":"/spectroscopy/absorption-cross-section","description":"σ = ε · 1000 / (N_A · ln 10) — convert molar extinction coefficient to molecular cross-section.","kind":"page","category":"spectroscopy","tags":["spectroscopy","absorption-cross-section","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Absorption Depth Calculator","href":"/spectroscopy/absorption-depth","description":"Calculate absorption depth δ = 1/α and explore spectral dependence for common optical materials.","kind":"page","category":"spectroscopy","tags":["spectroscopy","absorption-depth","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Accessible Emission Limits (AEL)","href":"/laser-safety/ael-limits","description":"IEC 60825-1 laser classification AEL thresholds. Simplified model for educational reference.","kind":"page","category":"laser-safety","tags":["laser-safety","ael-limits","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Acousto-Optic Materials","href":"/materials/acousto-optic","description":"Acousto-optic figure of merit, Bragg angle, and deflection calculations","kind":"page","category":"materials","tags":["materials","acousto-optic","sellmeier","dispersion","glass","index","material properties"],"priority":50},{"title":"Acquisition Tracking","href":"/free-space-comms/acquisition-tracking","description":"Open Acquisition Tracking.","kind":"page","category":"free-space-comms","tags":["free-space-comms","acquisition-tracking","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Adaptive Optics","href":"/free-space-comms/adaptive-optics","description":"Open Adaptive Optics.","kind":"page","category":"free-space-comms","tags":["free-space-comms","adaptive-optics","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Adaptive Optics Calculator","href":"/imaging/adaptive-optics","description":"AO correction performance, Strehl ratio, and deformable mirror requirements.","kind":"page","category":"imaging","tags":["imaging","adaptive-optics","resolution","na","microscopy","airy","mtf","psf"],"priority":50},{"title":"Adaptive Optics Gain","href":"/free-space-comms/adaptive-optics-gain","description":"Open Adaptive Optics Gain.","kind":"page","category":"free-space-comms","tags":["free-space-comms","adaptive-optics-gain","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Adaptive Optics in Microscopy","href":"/imaging/adaptive-optics-microscopy","description":"Wavefront correction, Strehl ratio recovery, and resolution improvement for deep-tissue imaging.","kind":"page","category":"imaging","tags":["imaging","adaptive-optics-microscopy","resolution","na","microscopy","airy","mtf","psf"],"priority":50},{"title":"Adhesion Testing","href":"/thin-film/adhesion-testing","description":"Model thin film adhesion properties from scratch test, peel test, tape test, and bend test. Calculate adhesion energy, interfacial shear strength, and critical loads.","kind":"page","category":"thin-film","tags":["thin-film","adhesion-testing","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Afocal System Calculator","href":"/imaging/afocal","description":"Design and analyze afocal (telescopic) relay systems — Keplerian and Galilean configurations.","kind":"page","category":"imaging","tags":["imaging","afocal","resolution","na","microscopy","airy","mtf","psf"],"priority":50},{"title":"Afterpulsing in APDs","href":"/detectors/afterpulsing","description":"Afterpulse probability, trap dynamics, and dead time trade-offs in avalanche photodiodes.","kind":"page","category":"detectors","tags":["detectors","afterpulsing","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"Aging of Optical Materials","href":"/materials/aging-effects","description":"Long-term degradation: transmission loss, solarization, compaction, stress relaxation","kind":"page","category":"materials","tags":["materials","aging-effects","sellmeier","dispersion","glass","index","material properties"],"priority":50},{"title":"Amplifier Noise","href":"/detectors/amplifier-noise","description":"Input-referred noise sets the detection floor. σ_amp = e_n.","kind":"page","category":"detectors","tags":["detectors","amplifier-noise","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"Amplitude Splitting","href":"/thin-film/amplitude-splitting","description":"Multiple-beam interference from amplitude splitting at a thin film. Shows how partial reflections from each interface combine to form interference fringes.","kind":"page","category":"thin-film","tags":["thin-film","amplitude-splitting","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Angle Tuning of Coatings","href":"/thin-film/angle-tuning","description":"Changing the angle of incidence shifts the spectral response of thin film coatings toward shorter wavelengths (blue shift). TE (s-polarization) and TM (p-polarization) respond differently, with TM showing reduced reflectance at Brewster&apos;s angle. The shift follows λ(θ) ≈ λ₀·√(1 − (n₀ sin θ/neff)²).","kind":"page","category":"thin-film","tags":["thin-film","angle-tuning","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Angle-Dependent Blue Shift","href":"/thin-film/angle-shift","description":"How the effective design wavelength shifts with angle of incidence (blue shift).","kind":"page","category":"thin-film","tags":["thin-film","angle-shift","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"ANSI vs IEC MPE Comparison","href":"/laser-safety/ansi-iec-comparison","description":"Compares Maximum Permissible Exposure (ANSI Z136.1) with Accessible Emission Limits (IEC 60825-1) across wavelengths.","kind":"page","category":"laser-safety","tags":["laser-safety","ansi-iec-comparison","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Anti-Blooming Design","href":"/detectors/antiblooming","description":"Anti-blooming shunts excess charge to drain when well exceeds threshold. Trade-off: charge dump efficiency vs full well capacity and linearity.","kind":"page","category":"detectors","tags":["detectors","antiblooming","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"Anti-Fog Coating Design","href":"/thin-film/anti-fog","description":"Hydrophilic thin film that spreads condensation into a uniform water layer, minimizing scattering.","kind":"page","category":"thin-film","tags":["thin-film","anti-fog","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Aperture Averaging","href":"/free-space-comms/aperture-averaging","description":"Open Aperture Averaging.","kind":"page","category":"free-space-comms","tags":["free-space-comms","aperture-averaging","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Apodization Comparison","href":"/spectroscopy/apodization-comparison","description":"Compare 9 window functions and their instrument line shapes (ILS). Select windows to overlay.","kind":"page","category":"spectroscopy","tags":["spectroscopy","apodization-comparison","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Apodization Functions","href":"/spectroscopy/apodization","description":"Window functions and their instrument line shapes (ILS). Trade-off: resolution vs sidelobe suppression.","kind":"page","category":"spectroscopy","tags":["spectroscopy","apodization","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Atmospheric Attenuation","href":"/laser-safety/atmospheric-attenuation","description":"Calculates atmospheric beam attenuation using Beer-Lambert law with water vapor absorption, CO₂ absorption, Rayleigh and Mie scattering. Useful for outdoor laser safety NOHD calculations.","kind":"page","category":"laser-safety","tags":["laser-safety","atmospheric-attenuation","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Atmospheric Loss","href":"/free-space-comms/atmospheric-loss","description":"Open Atmospheric Loss.","kind":"page","category":"free-space-comms","tags":["free-space-comms","atmospheric-loss","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Atmospheric Transmission","href":"/free-space-comms/atmosphere","description":"Molecular and aerosol extinction for free-space optical links.","kind":"page","category":"free-space-comms","tags":["free-space-comms","atmosphere","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Attosecond Pulse Generation","href":"/wave-optics/attosecond-pulse","description":"High-harmonic generation and isolated attosecond pulse parameters.","kind":"page","category":"wave-optics","tags":["wave-optics","attosecond-pulse","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Avalanche Photodiode Gain","href":"/detectors/avalanche-gain","description":"APD multiplication gain, excess noise factor (McIntyre), and material comparison.","kind":"page","category":"detectors","tags":["detectors","avalanche-gain","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"Aversion Response Time","href":"/laser-safety/aversion-response","description":"Calculates MPE at the natural aversion/blink response time (0.25 s) and Class 2 limits per ANSI Z136.1 / IEC 60825-1.","kind":"page","category":"laser-safety","tags":["laser-safety","aversion-response","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Back-Illuminated vs Front-Illuminated","href":"/detectors/back-illumination","description":"Back-illuminated sensors bypass gate structures for higher QE and better blue/UV response.","kind":"page","category":"detectors","tags":["detectors","back-illumination","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"Background Noise","href":"/free-space-comms/background-noise","description":"Open Background Noise.","kind":"page","category":"free-space-comms","tags":["free-space-comms","background-noise","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Bandpass Filter","href":"/thin-film/bandpass-filter","description":"Fabry-Perot bandpass — multi-cavity design with quarter-wave mirrors and half-wave spacers.","kind":"page","category":"thin-film","tags":["thin-film","bandpass-filter","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Bandwidth vs Noise Trade-off","href":"/detectors/bandwidth","description":"Noise increases with √Δf. Wider bandwidth = faster response but more noise.","kind":"page","category":"detectors","tags":["detectors","bandwidth","sensor","noise","qe","responsivity","nep","detectivity"],"priority":50},{"title":"Beam Diameter Conversion","href":"/laser-safety/beam-diameter-conversion","description":"Convert between 1/e², 1/e, and FWHM beam diameter definitions for Gaussian beams.","kind":"page","category":"laser-safety","tags":["laser-safety","beam-diameter-conversion","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Beam Divergence Hazards","href":"/laser-safety/beam-divergence-hazards","description":"Model Gaussian beam propagation and hazard distance based on beam divergence and MPE limits.","kind":"page","category":"laser-safety","tags":["laser-safety","beam-divergence-hazards","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Beam Expander Safety","href":"/laser-safety/beam-expander","description":"Calculate power density reduction from beam expansion. Critical for ensuring safe irradiance levels.","kind":"page","category":"laser-safety","tags":["laser-safety","beam-expander","laser safety","mpe","nohd","od","eyewear","hazard"],"priority":50},{"title":"Beam Quality Factor M²","href":"/wave-optics/m2-factor","description":"M² = (π w₀ θ)/λ. M² = 1 for ideal Gaussian, higher for multimode beams.","kind":"page","category":"wave-optics","tags":["wave-optics","m2-factor","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Beam Quality M² Measurement","href":"/wave-optics/beam-quality","description":"Detailed beam quality analysis from measured parameters.","kind":"page","category":"wave-optics","tags":["wave-optics","beam-quality","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Beam Waist Matching","href":"/wave-optics/beam-waist-matching","description":"Find the optimal lens for coupling one Gaussian mode into another.","kind":"page","category":"wave-optics","tags":["wave-optics","beam-waist-matching","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Beam Wander","href":"/free-space-comms/beam-wander","description":"Open Beam Wander.","kind":"page","category":"free-space-comms","tags":["free-space-comms","beam-wander","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Beamsplitter Design","href":"/thin-film/beamsplitter","description":"Dielectric beamsplitters split light into reflected and transmitted beams. A single quarter-wave layer gives R &lt; 50% for most materials; multilayer (HL)N stacks approach 100%. A 50/50 split is achieved with specific layer thicknesses (non-quarter-wave) or by selecting the appropriate number of layer pairs near the stop band edge.","kind":"page","category":"thin-film","tags":["thin-film","beamsplitter","coating","ar","dielectric stack","bragg","reflectance"],"priority":50},{"title":"Beer-Lambert Absorption","href":"/spectroscopy/absorption","description":"A = ε·c·l — absorbance from molar extinction coefficient, concentration, and path length.","kind":"page","category":"spectroscopy","tags":["spectroscopy","absorption","beer lambert","ftir","blackbody","raman","wavenumber"],"priority":50},{"title":"Bend-Insensitive Fiber Design","href":"/fiber-optics/bend-insensitive","description":"Design and analyze bend-insensitive fibers with depressed cladding trenches (ITU-T G.657).","kind":"page","category":"fiber-optics","tags":["fiber-optics","bend-insensitive","fiber","mfd","na","dispersion","splice","coupling"],"priority":50},{"title":"Ber","href":"/free-space-comms/ber","description":"Open Ber.","kind":"page","category":"free-space-comms","tags":["free-space-comms","ber","fso","link budget","fog","scintillation","pointing"],"priority":50},{"title":"Bessel Beam Calculator","href":"/wave-optics/bessel-beam","description":"Non-diffracting beam profiles and propagation.","kind":"page","category":"wave-optics","tags":["wave-optics","bessel-beam","gaussian beam","abcd","cavity","mode matching","diffraction"],"priority":50},{"title":"Birefringence & Retardation","href":"/polarization/birefringence","description":"Phase retardation from crystal birefringence, thickness, and wavelength.","kind":"page","category":"polarization","tags":["polarization","birefringence","stokes","jones","mueller","waveplate","polarizer"],"priority":50},{"title":"Birefringence Fiber","href":"/fiber-optics/birefringence-fiber","description":"Open Birefringence Fiber.","kind":"page","category":"fiber-optics","tags":["fiber-optics","birefringence-fiber","fiber","mfd","na","dispersion","splice","coupling"],"priority":50},{"title":"Birefringence Imaging","href":"/polarization/birefringence-imaging","description":"Simulate quantitative birefringence imaging with polarizer/analyzer rotation and compensators. Visualize stress-induced birefringence patterns.","kind":"page","category":"polarization","tags":["polarization","birefringence-imaging","stokes","jones","mueller","waveplate","polarizer"],"priority":50},{"title":"Birefringent Crystals","href":"/materials/birefringent-crystals","description":"Ordinary (nₒ) and extraordinary (nₑ) refractive indices","kind":"page","category":"materials","tags":["materials","birefringent-crystals","sellmeier","dispersion","glass","index","material properties"],"priority":50},{"title":"Birefringent Polarizer Design","href":"/polarization/birefringent-polarizer","description":"Compare Glan, Wollaston, Rochon, and Senarmont polarizer designs us